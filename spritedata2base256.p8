pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
function sprite2base256(sx,sy,sw,sh)

	local reserve=""
	
	for i=0,sw*sh-1 do
		reserve..=num2base256(sget(i%sw+sx,i/sw+sy)+1)
	end
	
	return reserve

end

function sspr_256(data,x,y,w,h)
	for j=0,#data do
		pset(j%w+x,j/w+y,ord(data[j+1])-1)
	end
end

function num2base256(number)
  return number%256==0 and "\\000" or number==10 and "\\n" or number==13 and "\\r" or number==34 and [[\"]] or number==92 and [[\\]] or chr(number)
end

data=sprite2base256(8,0,8,8)
sspr_256(data,32,32,8,8)
__gfx__
