pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
cls()color(2)

function get_sprdata(w,h)

  local reserve=""
  for i=0,w*h-1 do
--    reserve..=num2base256(sget(i%w,i\w)+1)
			reserve..=chr(sget(i%w,i/w)+1)
  end
  return reserve
  
end

function sspr_256(data,w,h)
	for j=0,#data-1,1 do
		pset(j%w,j/w,ord(data[j+1])-1)
	end
end

function num2base256(number)
--  return number%256==0 and "\\000" or number==10 and "\\n" or number==13 and "\\r" or number==34 and [[\"]] or number==92 and [[\\]] or chr(number)
	return chr(number)
end

data=get_sprdata(128,128)

function _draw()
cls()
sspr_256(data,128,128)
end

